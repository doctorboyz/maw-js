{
  "name": "bud",
  "version": "1.0.0",
  "entry": "./index.ts",
  "sdk": "^1.0.0",
  "description": "Create a new oracle (bud from parent)",
  "cli": {
    "command": "bud",
    "help": "maw bud <name> [--from <oracle>] [--root] [--org <org>] [--repo org/repo] [--issue N] [--note <text>] [--fast] [--dry-run]",
    "flags": {
      "--from": "string", "--org": "string", "--repo": "string",
      "--issue": "number", "--note": "string",
      "--fast": "boolean", "--root": "boolean", "--dry-run": "boolean"
    }
  },
  "api": { "path": "/api/bud", "methods": ["POST"] }
}
